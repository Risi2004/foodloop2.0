MONGO_URI=mongodb://127.0.0.1:27017/foodloop
PORT=5000
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Gmail via Nodemailer (use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=FoodLoop <your.email@gmail.com>

# Cloudflare R2 (signup PDFs and profile images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=foodloop-uploads
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
