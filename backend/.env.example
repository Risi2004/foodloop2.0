# FoodLoop Backend — copy to .env and fill in real values
#   cp .env.example .env
#
# Production (Render): see ../DEPLOYMENT.md — use MongoDB Atlas, not local Mongo.

# =============================================================================
# Server
# =============================================================================
PORT=5000
# Local Vite dev server:
FRONTEND_URL=http://localhost:5173
# Production (Render) — your Vercel app URL, no trailing slash:
# FRONTEND_URL=https://your-app.vercel.app
# Optional: extra allowed origins (FRONTEND_URL is always included):
# CORS_ORIGINS=https://staging.example.com
# Vercel preview deploys (*.vercel.app) are allowed by default; set to disable:
# ALLOW_VERCEL_PREVIEWS=false

# =============================================================================
# Routing (OSRM proxy for driver ETA / demo routes)
# =============================================================================
# Default: public OSRM demo server. For production, self-host OSRM and set:
# OSRM_BASE_URL=https://your-osrm-host

# =============================================================================
# Weather (OpenWeather API proxy)
# =============================================================================
# https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key
# Optional override for enterprise/proxy weather endpoints:
# WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# =============================================================================
# Database (required)
# =============================================================================
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/foodloop
# MongoDB Atlas (required on Render):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/foodloop?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/foodloop

# =============================================================================
# JWT auth (required)
# =============================================================================
# Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# =============================================================================
# Email — Nodemailer / Gmail (required for OTP, signup, admin notifications)
# =============================================================================
# Use a Google App Password, not your normal Gmail password:
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=FoodLoop <your.email@gmail.com>

# =============================================================================
# Cloudflare R2 — signup PDFs and profile images (required for file upload signup)
# =============================================================================
# Dashboard: R2 → bucket → public URL + API token (Object Read & Write)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=foodloop-uploads
# Public base URL with no trailing slash (e.g. https://pub-xxxx.r2.dev)
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# =============================================================================
# Google Gemini — donation food image analysis (required for analyze-image)
# =============================================================================
# API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_key
# Vision + JSON model (override if needed)
GEMINI_MODEL=gemini-2.5-flash