# FoodLoop Frontend — copy to .env and adjust if needed
#   cp .env.example .env
#
# Production (Vercel): see ../DEPLOYMENT.md

# =============================================================================
# API base URL (Vite — must start with VITE_)
# =============================================================================
# Local dev (recommended): leave empty — Vite proxies /api, /uploads, and /socket.io
# to http://localhost:5000 (see vite.config.js → server.proxy)
VITE_API_URL=

# Production (Vercel) — your Render backend URL, no trailing slash:
# VITE_API_URL=https://foodloop-api.onrender.com
#
# Custom API domain:
# VITE_API_URL=https://api.yourdomain.com
#
# After changing VITE_API_URL on Vercel, redeploy so the new value is baked into the build.

# Optional — footer social links (open in new tab when icons are clicked)
# VITE_SOCIAL_WHATSAPP_URL=https://wa.me/947XXXXXXXX
# VITE_SOCIAL_FACEBOOK_URL=https://www.facebook.com/yourpage
# VITE_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/yourpage
# VITE_SOCIAL_TWITTER_URL=https://x.com/yourpage
# =============================================================================
# Built-in (do not set in .env — set by Vite automatically)
# =============================================================================
# import.meta.env.DEV  — true in dev server
# import.meta.env.PROD — true in production build
# import.meta.env.MODE — "development" | "production"
