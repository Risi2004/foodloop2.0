# FoodLoop Frontend — copy to .env and adjust if needed
#   cp .env.example .env

# =============================================================================
# API base URL (Vite — must start with VITE_)
# =============================================================================
# Local dev (recommended): leave empty — Vite proxies /api and /uploads to the backend
# See frontend/vite.config.js → server.proxy → http://localhost:5000
VITE_API_URL=

# Production or custom API host (no trailing slash), e.g.:
# VITE_API_URL=https://api.yourdomain.com

# =============================================================================
# Built-in (do not set in .env — set by Vite automatically)
# =============================================================================
# import.meta.env.DEV  — true in dev server
# import.meta.env.PROD — true in production build
# import.meta.env.MODE — "development" | "production"
